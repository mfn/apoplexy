# May be created by apoplexy, PR et al. during operation.
unknown/*
levels/*
levels2/*
/upack.bat
xml/*

# Executables.
/apoplexy
/apoplexy.exe
/apoplexy.dSYM/

# vcpkg (project-local toolchain + installed deps for the macOS build).
/.vcpkg/
/.vcpkg-shim/
/vcpkg_installed/

# PR (Princed Resources) macOS build (no upstream binary; built from
# pr/PR-1.3.1-prerelease.ZIP by scripts/build-macos.sh).
/.pr-build/
/pr/pr-darwin

# Created by IDE's, in particular Dev-C++.
/src/apoplexy.dev
/src/apoplexy.ico
/src/apoplexy.layout
/src/apoplexy.o
/src/*private*
/src/Makefile.win

# We want empty prince/, prince2/ and snes/ directories.
prince/*
!/prince/empty.txt
prince2/*
!/prince2/empty.txt
snes/*
!/snes/empty.txt
