# May be created by apoplexy, PR et al. during operation.
unknown/*
levels/*
levels2/*
/upack.bat
xml/*

# Executables.
/apoplexy
/apoplexy.exe
/apoplexy.dSYM/

# CMake build trees.
/build/

# vcpkg (project-local toolchain + installed deps for the macOS build).
/.vcpkg/
/.vcpkg-shim/
/vcpkg_installed/

# PR (Princed Resources) runtime outputs built from third_party/PR.
/.pr-build/
/pr/pr
/pr/pr.exe
/pr/pr-darwin
/pr/resources.xml
/pr/pop2.xml

# Created by IDE's, in particular Dev-C++.
/src/apoplexy.dev
/src/apoplexy.ico
/src/apoplexy.layout
/src/apoplexy.o
/src/*private*
/src/Makefile.win

# We want empty prince/, prince2/ and snes/ directories.
prince/*
!/prince/empty.txt
prince2/*
!/prince2/empty.txt
snes/*
!/snes/empty.txt
